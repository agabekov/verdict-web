{
  "functions": {
    "api/movie/[id].js": {
      "maxDuration": 10
    },
    "api/tv/[id].js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/movie/(.*)",
      "destination": "/api/movie/$1"
    },
    {
      "source": "/tv/(.*)",
      "destination": "/api/tv/$1"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}