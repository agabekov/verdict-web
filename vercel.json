{
  "functions": {
    "api/[id].js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/movie/(.*)",
      "destination": "/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}